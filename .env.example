# =============================================================================
# Solodova Recovery System - пример переменных окружения. Скопируй в .env и заполни реальными
# значениями. Файл .env в git не попадает.
# =============================================================================

# -------------------- Node --------------------
NODE_ENV=development

# -------------------- PostgreSQL --------------------
POSTGRES_USER=srs
POSTGRES_PASSWORD=srs_dev_pwd
POSTGRES_DB=srs
# 5433 по умолчанию, чтобы не конфликтовать с локальным Postgres
POSTGRES_PORT=5433
# DATABASE_URL используется Prisma и приложением API
DATABASE_URL="postgresql://srs:srs_dev_pwd@localhost:5433/srs?schema=public"
# Shadow DB для prisma migrate dev (не обязательно, создаётся автоматически)
SHADOW_DATABASE_URL="postgresql://srs:srs_dev_pwd@localhost:5433/srs_shadow?schema=public"

# -------------------- Redis --------------------
REDIS_PORT=6379
REDIS_URL="redis://localhost:6379"

# -------------------- S3 / MinIO --------------------
S3_ACCESS_KEY=srs
S3_SECRET_KEY=srs_dev_pwd
S3_BUCKET=srs-dev
S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:9000
S3_PORT=9000
S3_CONSOLE_PORT=9001
S3_FORCE_PATH_STYLE=true

# -------------------- Adminer --------------------
ADMINER_PORT=8085

# -------------------- API --------------------
API_PORT=3000
API_HOST=0.0.0.0
# Префикс со встроенной версией (URI versioning в Nest 11 + Express 5 имеет баг).
# Когда понадобится /api/v2, заведите отдельные контроллеры по ТЗ v2.
API_GLOBAL_PREFIX=api/v1
API_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8081,http://localhost:19006

# -------------------- Локальная админка (staff login) --------------------
DEV_ADMIN_EMAIL=admin@solodova-recovery.local
DEV_ADMIN_PASSWORD=DevAdminChangeMe!
DEV_ADMIN_PHONE=+79000000000

# -------------------- JWT --------------------
# Сгенерируй новый секрет: openssl rand -base64 64
JWT_ACCESS_SECRET=replace_me_with_a_64_byte_base64_secret_in_real_env
JWT_REFRESH_SECRET=replace_me_with_another_64_byte_base64_secret_in_real_env
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# -------------------- Encryption для медицинских данных (AES-256-GCM) --------------------
# Ровно 32 байта в base64: openssl rand -base64 32
DATA_ENCRYPTION_KEY=replace_me_with_32_byte_base64_key

# -------------------- OTP (SMS) --------------------
# Провайдер: smsc | sms_aero | console (для локалки пишем код в логи)
OTP_PROVIDER=console
OTP_CODE_LENGTH=6
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60
SMSC_LOGIN=
SMSC_PASSWORD=
SMS_AERO_EMAIL=
SMS_AERO_KEY=

# -------------------- Push-уведомления (Expo Push) --------------------
# console — только запись уведомлений в БД (по умолчанию, dev).
# expo — реальная отправка при публикации контента и т.д. через https://exp.host/--/api/v2/push/send
PUSH_PROVIDER=console
# Токен из https://expo.dev/accounts/<account>/settings/access-tokens (повышает лимиты API; можно оставить пустым для низких лимитов)
EXPO_ACCESS_TOKEN=
# Зарезервировано под прямую интеграцию FCM (пока не используется в коде API).
FCM_SERVER_KEY=

# -------------------- Логирование --------------------
LOG_LEVEL=debug
LOG_PRETTY=true

# -------------------- Rate limit --------------------
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=100

# -------------------- Alerts (queues: reminders/lifecycle) --------------------
# WARN/CRITICAL пороги для delayed jobs в GET /api/v1/health/queues
ALERT_REMINDER_DELAYED_WARN=100
ALERT_REMINDER_DELAYED_CRITICAL=300
ALERT_LIFECYCLE_DELAYED_WARN=50
ALERT_LIFECYCLE_DELAYED_CRITICAL=150

# -------------------- Тесты --------------------
TEST_DATABASE_URL="postgresql://srs:srs_dev_pwd@localhost:5433/srs_test?schema=public"
