# Tenant: solodova-staging — мобильное приложение Solodova против staging VPS
# Активация: pnpm mobile:tenant use solodova-staging
#
# Перед запуском на физическом устройстве убедитесь, что API доступен с телефона
# (тот же Wi‑Fi / VPN). Для эмулятора Android используйте 10.0.2.2 вместо IP.

TENANT_SLUG=solodova
TENANT_DISPLAY_NAME=Solodova Recovery System

EXPO_PUBLIC_API_BASE_URL=http://148.253.213.153:3000/api/v1

EXPO_PUBLIC_APP_DISPLAY_NAME=S.R.Solodova
EXPO_PUBLIC_APP_SLUG=solodova-recovery-system
EXPO_PUBLIC_ANDROID_PACKAGE=com.srs.solodova
EXPO_PUBLIC_IOS_BUNDLE_ID=com.srs.solodova
EXPO_PUBLIC_APP_SCHEME=mobile

EXPO_PUBLIC_BRAND_NAME=Solodova Recovery System
EXPO_PUBLIC_BRAND_SHORT_NAME=Solodova
EXPO_PUBLIC_STUDIO_LEGAL_NAME=Solodova Recovery System
EXPO_PUBLIC_PLATFORM_LEGAL_NAME=Podocare

EXPO_PUBLIC_PRIVACY_POLICY_URL=https://solodova-recovery.ru/privacy
EXPO_PUBLIC_PRIVACY_EMAIL=privacy@solodova-recovery.ru
EXPO_PUBLIC_SUPPORT_EMAIL=support@solodova.recovery
EXPO_PUBLIC_SUPPORT_PHONE=+79000000000
