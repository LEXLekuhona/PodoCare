{
  "name": "@srs/mobile",
  "main": "expo-router/entry",
  "version": "0.1.0",
  "scripts": {
    "dev": "expo start",
    "dev:client": "expo start --dev-client",
    "dev:clear": "expo start --clear",
    "dev:ci": "CI=1 expo start",
    "dev:clear:ci": "CI=1 expo start --clear",
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "ios:client": "expo start --dev-client --ios",
    "web": "expo start --web",
    "build": "expo export --platform web",
    "typecheck": "tsc --noEmit",
    "test": "jest --config jest.config.js",
    "clean": "rm -rf dist .turbo .expo .expo-shared node_modules"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo-google-fonts/plus-jakarta-sans": "^0.4.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-navigation/native": "^7.1.8",
    "@srs/shared-types": "workspace:*",
    "expo": "~54.0.34",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "^55.0.32",
    "expo-device": "~8.0.10",
    "expo-font": "~14.0.11",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.11",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
    "eas-cli": "^18.11.0",
    "jest": "^29.7.0",
    "react-test-renderer": "19.1.0",
    "ts-jest": "^29.4.9",
    "typescript": "~5.9.2"
  },
  "private": true
}
