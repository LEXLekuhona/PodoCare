# Базовый URL API. Для dev localhost/127.0.0.1 подставляется LAN-хост Metro с этого же ПК (Expo hostUri),
# иначе на Android-эмуляторе — 10.0.2.2. В tunnel (--tunnel) или нестандартной сети задайте полный URL вручную.
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000/api/v1

# Контакты поддержки (используются в разделе "Поддержка" в профиле).
# Если не заданы — кнопки «Написать на почту» и «Позвонить» становятся недоступны;
# отзывы (StudioReviewPage) идут на API через POST /reviews независимо от этих переменных.
# В production EAS-сборках задавайте через секреты:
#   eas secret:create --name EXPO_PUBLIC_SUPPORT_EMAIL --value support@solodova.recovery
#   eas secret:create --name EXPO_PUBLIC_SUPPORT_PHONE --value +74951234567
EXPO_PUBLIC_SUPPORT_EMAIL=support@solodova.recovery
EXPO_PUBLIC_SUPPORT_PHONE=+74951234567

# Перед входом по телефону из корня репозитория: pnpm dev:stack:infra
# (Docker + Postgres/Redis + миграции + API + Metro). Либо pnpm dev:android — с seed данных.

