# Переменные для docker compose -f docker-compose.prod.yml (корневой .env или export).
#
# URL API с точки зрения браузера пользователя (не внутренний hostname Docker).
# Локальный стек: http://localhost:3000/api/v1
# Продакшен:     https://api.your-domain.com/api/v1
VITE_API_URL=http://localhost:3000/api/v1

# Origin админки для CORS на API (должен совпадать с URL, по которому открываете админку).
API_CORS_ORIGINS=http://localhost:8080

# Порт публикации nginx с админкой на хосте
ADMIN_HTTP_PORT=8080
