{
  "extends": "@podocare/tsconfig/nestjs.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "./dist",
    "rootDir": "./",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@modules/*": ["src/modules/*"],
      "@common/*": ["src/common/*"],
      "@infra/*": ["src/infrastructure/*"],
      "@config/*": ["src/config/*"],
      "@test/*": ["test/*"]
    }
  },
  "include": ["src/**/*", "test/**/*", "prisma/**/*.ts"],
  "exclude": ["node_modules", "dist", "coverage"]
}
