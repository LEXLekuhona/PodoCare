// =============================================================================
// Solodova Recovery System — Prisma schema (v2, content-first).
//
// Принципы:
// • Мульти-студийная модель: операционные сущности (услуги, записи, мастера)
//   привязаны к studio_id. Контент, программы, квизы — глобальные для сети.
// • Все ID — UUID v4, генерируются Postgres'ом.
// • snake_case в БД, camelCase в коде (@map).
// • Даты в UTC (@db.Timestamptz).
// • Денежные суммы — целые числа в минимальных единицах валюты (копейки).
// • Чувствительные медицинские данные шифруются на уровне приложения
//   (AES-256-GCM). В БД — только cipher blob + iv + auth_tag.
// • Фото/клинические снимки — НЕ храним (решение клиента).
// • Soft delete не используется на старте. Аудит-лог фиксирует изменения.
//
// Ядро продукта — контент и прогрев:
//   DiagnosticQuiz → ContentSeries → ContentCta → (Service | Program |
//                                                   ContentSeries | PhysicalGood)
//   FunnelEvent фиксирует путь пользователя для сегментации.
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

